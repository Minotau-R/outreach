Thomaz Bastiaanssen: library(igraph)
library(igraph)
library(tidyverse)
randomize_weights <- function(g) igraph::set_edge_attr(
g, "weight", value = exp(rnorm(length(igraph::E(g))))
)
make_lattice(c(10, 10)) %>%
randomize_weights() %>%
mst() %>% plot()
make_lattice(c(10, 10)) %>%
randomize_weights() %>%
mst() %>%
tidygraph::as_tbl_graph() %>%
activate("nodes") %>%
mutate(x = rep(1:10, 10), y = rep(1:10, each = 10)) %>%
plot()
